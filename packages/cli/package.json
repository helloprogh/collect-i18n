{
  "name": "@collect-i18n/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/bin.js",
  "types": "dist/index.d.ts",
  "bin": {
    "collect-i18n": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/cli/src",
    "dev": "tsx src/bin.ts"
  },
  "dependencies": {
    "@collect-i18n/analyzer": "workspace:*",
    "@collect-i18n/core": "workspace:*",
    "@collect-i18n/excel": "workspace:*",
    "@collect-i18n/runner": "workspace:*",
    "@collect-i18n/runtime": "workspace:*",
    "@collect-i18n/vite-vue": "workspace:*",
    "commander": "^14.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
